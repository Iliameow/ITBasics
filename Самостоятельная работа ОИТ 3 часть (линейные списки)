// Добавление нового элемента в линейный список
Elem* AddNewElemLinearList(Elem* head, FigureSkating participant)
{
	// Переменная для хранения нового узла
	Elem* newElem = new Elem(participant);
	// Проверка на пустоту списка
	if (head == nullptr) {
		head = newElem;
	}
	// Вставка в начало списка (новая голова)
	else if (participant.age < head->value.age ||
		participant.age == head->value.age &&
		participant.surname + participant.name < head->value.surname + head->value.name)
	{
		newElem->next = head;
		head = newElem;
	}
	else {
		Elem* curr = head;
		bool done = false;
		while (!done) {
			// Вставка в конец списка
			if (curr->next == nullptr) {
				curr->next = newElem;
				done = true;
			}
			// Проверка, куда необходимо вставить элемент, если вставлять его в середину списка
			else if (participant.age < curr->next->value.age ||
				participant.age == curr->next->value.age &&
				participant.surname + participant.name < curr->next->value.surname + curr->next->value.name) {
				newElem->next = curr->next;
				curr->next = newElem;
				done = true;
			}
			// Сдвиг далее, если не вставляем
			else {
				curr = curr->next;
			}
		}
	}
	return head;
}

// Ввод данных с клавиатуры в линейный список
Elem* LinearListConsoleInput(int records) {
