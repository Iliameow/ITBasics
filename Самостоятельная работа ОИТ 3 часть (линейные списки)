// Структура данных
struct FigureSkating
{
	string surname; // фамилия
	string name; // имя
	string country; // страна, от которой выступает фигуристка
	unsigned int age; // возраст
	double shortProgramRate; // баллы за короткую программу
	double freeScatingRate; // баллы за произвольную программу
};

// Структура линейного списка
struct Elem
{
	FigureSkating value; // поле для хранения записи о фогуристе
	Elem* next; // ссылка на следующий элемент списка

	// Конструктор нового узла
	Elem(FigureSkating value) : value(value), next(nullptr) {}
};

// Ввод целого числа >= 0
int UnsignedIntInput(string welcome, string error)
{
	string strInput;
	int UnsignedIntInput;
	cout << welcome << endl;
	cin >> strInput;
	// Переменная для проверки корректности введённого числа для выполнения цикла 
	bool test = false;
	while (!test) {
		stringstream ss(strInput);
		// Пишем таким образом, учитывая особенность функции ss проверять возможность перевода типа и записи в переменную, пока может конвертировать тип
		char nextElem;
		// Преобразуем строку в int(вернёт true - если число, false - если нечисло)
		if (ss >> UnsignedIntInput && UnsignedIntInput >= 0) {
			// Проверяем элемент, следующий за прочитанным числом, если его нет, то в строке только число, если есть, то помимо числа есть другие символы, а значит, ввод не корректный
			if (!(ss >> nextElem)) {
				// Число введено корректно
				test = true;
				break;
			}
			else {
				cout << error << " " << welcome << endl;
				cin >> strInput;
			}
		}
		else {
			cout << error << " " << welcome << endl;
			cin >> strInput;
		}
	}
	return UnsignedIntInput;
}

