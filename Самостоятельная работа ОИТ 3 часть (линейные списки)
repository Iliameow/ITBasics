	Elem* head = nullptr;
	for (int i = 0; i < records; i++) {
		FigureSkating newElem = StructureInput();
		head = AddNewElemLinearList(head, newElem);
	}
	return head;
}

// Ввод данных из файла
Elem* ReadFile(Elem* head)
{
	ofstream OutFile;
	string FileName = StrInput("Введите имя файла:");
	// Открываем файл для записи, связав его с файлом на внешнем запоминающем устройсте:
	ifstream InFile(FileName);
	// Строка для ввода (считывания) строк текста из файла
	string InLineVar;
	// Переменная для нумерации строк, считанных из файла
	int SN = 0;
	// Проверяем, удалось ли открыть файл, если удалось, считываем из него в цикле текстовые строки и выводим в консоль:
	if (InFile.is_open())
	{
		while (getline(InFile, InLineVar))
		{
			SN++;
			cout << "Считывание строки: " << InLineVar << endl;
			// Выделяем номер строки и текст (через разделитель -) и записываем данные без номера строки в массив записей
			int SymbPosition = InLineVar.find("-", 1);
			// Служебный массив строк, для считывания записи по полям через пробел
			string* helpArr = new string[6];
			// Записываем поток из записи
			istringstream iss(InLineVar.substr(SymbPosition + 2));
			for (int i = 0; i < 6; i++) {
				// на каждое место в массиве записываем по одному полю записи, разделяя их по пробелам
				iss >> helpArr[i];
			}
			// Переписываем данные в структуру FigureSkating
			FigureSkating participant;
			participant.name = helpArr[0];
			participant.surname = helpArr[1];
			participant.country = helpArr[2];
			participant.age = stoi(helpArr[3]);
			participant.shortProgramRate = stod(helpArr[4]);
			participant.freeScatingRate = stod(helpArr[5]);
			delete[] helpArr;
			// Добавление новой записи в линейный список, переданный в функцию по голове
			head = AddNewElemLinearList(head, participant);
		}
		InFile.close();
		cout << SN << " Данные успешно считаны." << endl;
	}
	else
	{
		cout << "Не удалось прочитать данные из файла!" << endl;
	}
	return head;
}

