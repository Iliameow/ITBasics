// Вывод линейного списка в консоль по возрастанию/неубыванию
void PrintIncreasedLinearList(Elem* head)
{
	// Пока не дошли до конца списка, выводим значения в узлах
	while (head != nullptr) {
		Print(head->value);
		head = head->next;
	}
}

// Вывод линейного списка в консоль по убыванию/невозрастанию
void PrintDecreasedLinearList(Elem* head)
{
	// Базовый случай - дошли до конца списка
	if (head == nullptr) {
		return;
	}
	PrintDecreasedLinearList(head->next);
	Print(head->value);
}

// Итерационный алгоритм поиска по возрасту
bool IterativeSearchElem(Elem* head, unsigned int findAge)
{
	// Переменная для отметки того, что найден хотя бы один элемент
	bool found = false;
	// Пока не дошли до конца списка
	while (head != nullptr) {
		// Останавливаем проход по списку, 
		// если вывели все элементы с искомым значением атрибута
		if (head->value.age > findAge) {
			break;
		}
		else if (head->value.age == findAge) {
			Print(head->value);
			found = true;
			head = head->next;
		}
		else {
			head = head->next;
		}
	}
	return found;
}

// Рекурсивный алгоритм поиска по возрасту
bool RecursiveSearchElem(Elem* head, unsigned int findAge, bool found = false)
{
	// Базовый случай - дошли до конца списка
	if (head == nullptr) {
		return found;
	}
	if (head->value.age == findAge) {
		Print(head->value);
		found = true;
	}
	else if (head->value.age > findAge) {
		return found;
	}
	RecursiveSearchElem(head->next, findAge, found);
}

// Удаление элемента(-ов) с искомым значением аргумента, по которому выполнялась сортировка
Elem* DeleteElem(Elem* head, unsigned int deleteElem)
{
	bool ifDeleted = false;
	// Проверяем отдельно ситуацию, когда в списке только 1 элемент - его голова
	Elem* curr = head;
	if (head->value.age == deleteElem && head->next == nullptr) {
		head = nullptr;
		ifDeleted = true;
	}
	// В цикле проверяем, является ли следующий элемент пустым, 
	// для того, чтобы при удовлетворении условия, можно было удалить следующий за ним, 
	// перепривязав ссылку текущего на ссылку через один от него
	while (curr->next != nullptr) {
		// Замена головы списка в случае, если нужно удалить один или несколько первых элементов
		if (head != nullptr && head->value.age == deleteElem) {
			Elem* currHead = head;
			head = head->next;
			curr = head;
			delete currHead;
			ifDeleted = true;
		}
		else if (curr->next->value.age == deleteElem) {
			Elem* nextElem = curr->next;
			curr->next = curr->next->next;
			delete nextElem;
			ifDeleted = true;
		}
		else {
			curr = curr->next;
		}
	}
	// Проверка, был ли удаляемый элемент изначально
	if (ifDeleted) {
		cout << "Элемент успешно удалён." << endl;
	}
	else {
		cout << "Фигурист с таким возрастом не найден!" << endl;
	}
	return head;
}

