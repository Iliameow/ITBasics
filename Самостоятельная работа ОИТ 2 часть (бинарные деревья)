// Добавление записи в конец массива записей
FigureSkating* AddRecord(FigureSkating participant, FigureSkating* arr, int& records)
{
	FigureSkating* newArray = new FigureSkating[records + 1];
	for (int i = 0; i < records; i++) {
		newArray[i] = arr[i];
	}
	newArray[records] = participant;
	records++;
	return newArray;
}

// Добавление записи в указанное место
FigureSkating* AddRecord(int indexAdd, FigureSkating* arr, int& records)
{
	FigureSkating* newArray = new FigureSkating[records + 1];
	for (int i = 0; i < indexAdd; i++) {
		newArray[i] = arr[i];
	}
	newArray[indexAdd] = StructureInput();
	for (int i = indexAdd; i < records; i++) {
		newArray[i + 1] = arr[i];
	}

	records++;
	return newArray;
}

// Удаление записи из указанного места
FigureSkating* DeleteRecord(int indexDelete, FigureSkating* arr, int& records)
{
	FigureSkating* newArray = new FigureSkating[records - 1];
	for (int i = 0; i < indexDelete; i++) {
		newArray[i] = arr[i];
	}
	for (int i = indexDelete + 1; i < records; i++) {
		newArray[i - 1] = arr[i];
	}

	records--;
	return newArray;
}

