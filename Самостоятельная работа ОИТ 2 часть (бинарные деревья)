// Структура данных для узла бинарного дерева
struct Node
{
	unsigned int index; // индекс элемента в исходном массиве
	double value; // значение аргумента, по которому выполняется сортировка
	Node* left; // ссылка на левого потомка
	Node* right; // ссылка на правого потомка

	// Конструктор без параметров
	Node() : index(0), value(0), left(nullptr), right(nullptr) {}

	// Конструктор с параметром (для целого беззнакового числа - возраст фигуристки)
	Node(unsigned int index, unsigned int value) : index(index), value(value), left(nullptr), right(nullptr) {}
	// Конструктор с параметром (для вещественного числа - сумма баллов за КП и ПП)
	Node(unsigned int index, double value) : index(index), value(value), left(nullptr), right(nullptr) {}
};

