// Создание бинарного дерева С УЧЁТОМ ПОВТОРЯЮЩИХСЯ элементов по невычислимому атрибуту (возраст)
Node* CreateBinaryTreeAge(FigureSkating* arr, int records)
{
	// Проверка на пустой массив
	if (records < 0 || arr == nullptr) { return nullptr; }
	// Задаём первое значение списка в качестве корня дерева
	Node* root = new Node(0, arr[0].age);
	for (int i = 1; i < records; i++)
	{
		// Задаём отдельную переменную для просмотра предыдущего узла (чтобы не терять корень дерева)
		Node* prev = root;
		// Переменная для хранения текущего элемента (очередной записи в массиве)
		Node* curr = new Node(i, arr[i].age);
		// Проверка на вставку текущего узла на свободное место, пока ложь - элемент не вставлен
		bool done = false;
		while (!done)
		{
			// Если текущее значение меньше родительского, то вставляем его слева при первой возможности, 
			// иначе - идём по дереву влево
			if (curr->value < prev->value) {
				if (prev->left == nullptr) {
					prev->left = curr;
					done = true;
				}
				else {
					prev = prev->left;
				}
			}
			// Если текущее значение больше родительского, то вставляем его справа при первой возможности, 
			// иначе - идём по дереву вправо
			else if (curr->value > prev->value) {
				if (prev->right == nullptr) {
					prev->right = curr;
					done = true;
				}
				else {
					prev = prev->right;
				}
			}
			// Если текущее значение равно родительскому, то смотрим на алфавитный порядок фамилии, 
			// а затем имени и вставляем по аналогии с предыдущей логикой на свободное место, 
			// только теперь уже по другому атрибуту
			else {
				if (arr[curr->index].surname + arr[curr->index].name < arr[prev->index].surname + arr[prev->index].name) {
					if (prev->left == nullptr) {
						prev->left = curr;
						done = true;
					}
					else {
						prev = prev->left;
					}
				}
				else {
					if (prev->right == nullptr) {
						prev->right = curr;
						done = true;
					}
					else {
						prev = prev->right;
					}
				}
			}
		}
	}
	return root;
}

// Создание бинарного дерева БЕЗ учёта ПОВТОРЯЮЩИХСЯ элементов по вычислимому атрибуту (сумма баллов)
Node* CreateBinaryTreeSummRate(FigureSkating* arr, int records)
{
	// Проверка на пустой массив
	if (records < 0 || arr == nullptr) { return nullptr; }
	// Задаём первое значение списка в качестве корня дерева
	Node* root = new Node(0, arr[0].shortProgramRate + arr[0].freeScatingRate);
	for (int i = 1; i < records; i++)
	{
		// Задаём отдельную переменную для просмотра предыдущего узла (чтобы не терять корень дерева)
		Node* prev = root;
		// Переменная для хранения текущего элемента (очередной записи в массиве)
		Node* curr = new Node(i, arr[i].shortProgramRate + arr[i].freeScatingRate);
		// Проверка на вставку текущего узла на свободное место, пока ложь - элемент не вставлен
		bool done = false;
		while (!done)
		{
			// Если текущее значение меньше родительского, то вставляем его слева при первой возможности, 
			// иначе - идём по дереву влево
			if (curr->value < prev->value) {
				if (prev->left == nullptr) {
					prev->left = curr;
					done = true;
				}
				else {
					prev = prev->left;
				}
			}
			// Если текущее значение больше родительского, то вставляем его справа при первой возможности, 
			// иначе - идём по дереву вправо
			else if (curr->value > prev->value) {
				if (prev->right == nullptr) {
					prev->right = curr;
					done = true;
				}
				else {
					prev = prev->right;
				}
			}
			// При возможном равенстве значений вставляем направо
			else {
				if (prev->right == nullptr) {
					prev->right = curr;
					done = true;
				}
				else {
					prev = prev->right;
				}
			}
		}
	}
	return root;
}

// Вывод бинарного дерева по возрастанию
void RecurrentIncreaseReadBinaryTree(FigureSkating* arr, Node* root)
{
	// Базовый случай: если дошли до конца ветки
	if (root == nullptr) {
		return;
	}
	// Спускаемся максимально влево
	RecurrentIncreaseReadBinaryTree(arr, root->left);
	// На развороте рекурсии выводим значения
	Print(arr[root->index]);
	// Спускаемся максимально вниз вправо
	RecurrentIncreaseReadBinaryTree(arr, root->right);
}

// Вывод бинарного дерева по убыванию
void RecurrentDecreaseReadBinaryTree(FigureSkating* arr, Node* root)
{
	// Базовый случай: если дошли до конца ветки
	if (root == nullptr) {
		return;
	}
	// Спускаемся максимально вправо
	RecurrentDecreaseReadBinaryTree(arr, root->right);
	// На развороте рекурсии выводим значения
	Print(arr[root->index]);
	// Спускаемся максимально вниз влево
	RecurrentDecreaseReadBinaryTree(arr, root->left);
}

// Поиск по невычислимому атрибуту (возраст) вывод ВСЕХ значений с заданным атрибутом
// Рекуррентная реализация
bool RecurrentSearchAgeBinaryTree(FigureSkating* arr, Node* root, unsigned int searchAge, bool found = false)
{
	if (root == nullptr) {
		return found;
	}
	RecurrentSearchAgeBinaryTree(arr, root->left, searchAge, found);

	// Пройти ещё раз в поисках равных элементов со своевременным выходом, не обходя всё дерево полностью
	if (root->value == searchAge) {
		Print(arr[root->index]);
		found = true;
	}
	else if (searchAge > root->value) {
		found = true;
	}

	RecurrentSearchAgeBinaryTree(arr, root->right, searchAge, found);
}

// Поиск по невычислимому атрибуту (возраст) вывод одного значения с заданным атрибутом
// Итерационная реализация
bool IterativeSearchSummRateBinaryTree(FigureSkating* arr, Node* root, double searchSummRate)
{
	// Пока не дошли до нижнего элемента дерева
	while (root != nullptr) {
		// Если искомое значение меньше текущего, то спускаемся ниже по левой ссылке
		if (searchSummRate < root->value) {
			root = root->left;
		}
		// Если искомое значение больше текущего, то спускаемся ниже по правой ссылке
		else if (searchSummRate > root->value) {
			root = root->right;
		}
		// Иначе - элемент найден, выводим по индексу исходную запись из массива
		else {
			Print(arr[root->index]);
			return true; // возвращаем истину, так как в дальнейшем проверяем отсортированность массива
		}
	}
	return false; // возвращаем ложь, так как в дальнейшем проверяем отсортированность массива
}

