// Ввод целого числа
int IntInput(string welcome, string error, string outOfRangeError = "Выберите меньшее число!")
{
	string strInput;
	int intInput;
	cout << welcome << endl;
	cin >> strInput;
	// Переменная для проверки корректности введённого числа для выполнения цикла 
	bool test = false;
	while (!test) {
		stringstream ss(strInput); 
		// Пишем таким образом, учитывая особенность функции ss проверять возможность перевода типа и записи в переменную, пока может конвертировать тип
		char nextElem;
		// Преобразуем строку в int(вернёт true - если число, false - если нечисло)
		if (ss >> intInput && intInput >= 0) { 
			// Проверяем элемент, следующий за прочитанным числом, если его нет, то в строке только число, если есть, то помимо числа есть другие символы, а значит, ввод не корректный
			if (!(ss >> nextElem)) {
				// Число введено корректно
				test = true;
				break;
			}
			else {
				cout << error << " " << welcome << endl;
				cin >> strInput;
			}
		}
		else {
			cout << error << " " << welcome << endl;
			cin >> strInput;
		}
	}
	return intInput;
}

