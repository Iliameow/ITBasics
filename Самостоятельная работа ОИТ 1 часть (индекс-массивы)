}

// Сортировка индекса массива по возрастанию значений ключевых полей (невычислимый атрибут - age)
SkaterOnAge* IncreasingValueBubbleSortIndexArrayGivenAge(SkaterOnAge* indexArray, int records)
{
	bool flg; // флаг для проверки отсортированности массива на каждом шаге, для ускорения работы в некоторых ситуациях
	int value; // вспомогательная переменная для обмена элементов местами
	int index; // вспомогательная переменная для обмена индексов местами
	for (int i = 0; i < records - 1; i++) {
		flg = true;
		for (int j = 0; j < records - i - 1; j++) {
			if (indexArray[j].SkaterAge > indexArray[j + 1].SkaterAge) {
				value = indexArray[j + 1].SkaterAge;
				index = indexArray[j + 1].FullNum;
				indexArray[j + 1].SkaterAge = indexArray[j].SkaterAge;
				indexArray[j + 1].FullNum = indexArray[j].FullNum;
				indexArray[j].SkaterAge = value;
				indexArray[j].FullNum = index;
				flg = false;
			}
		}
		// Если не было произведено ни одного обмена за итерацию, значит, массив отсортирован
		if (flg) {
			break;
		}
	}
	return indexArray;
}

// Сортировка индекса массива по убыванию значений ключевых полей (Вычислимый атрибут - общая сумма баллов за короткую и произвольную программы)
SkaterOnSummRate* DecreasingValueImplementationSortIndexArrayCountSummRate(SkaterOnSummRate* indexArray, int records)
{
	int maxValue; // переменная для хранения значения текущего максимального элемента
	int value; // вспомогательная переменная для обмена элементов местами
	int index; // вспомогательная переменная для обмена индексов местами
	for (int i = 0; i < records - 1; i++) {
		maxValue = i;
		for (int j = i + 1; j < records; j++) {
			if (indexArray[j].SkaterSummRate > indexArray[maxValue].SkaterSummRate) {
				maxValue = j;
			}
		}
		if (maxValue != i) {
			value = indexArray[maxValue].SkaterSummRate;
			index = indexArray[maxValue].FullNum;
			indexArray[maxValue].SkaterSummRate = indexArray[i].SkaterSummRate;
			indexArray[maxValue].FullNum = indexArray[i].FullNum;
			indexArray[i].SkaterSummRate = value;
			indexArray[i].FullNum = index;
		}
	}
	return indexArray;
}

