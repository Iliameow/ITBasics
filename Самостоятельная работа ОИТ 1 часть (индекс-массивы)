	// Интерфейс выбора: 1) ввод значений из консоли; 2) ввод данных из файла; 3) вывод данных в файл; 4) вывод данных в консоль.
	int checkEnd = false;
	while (!checkEnd) 
	{
		cout << "Выберите номер желаемого действия:" << endl << "1) Ввод с клавиатуры из консоли;" << endl << "2) Ввод данных из файла;" << endl << "3) Вывод данных в файл;" << endl << "4) Вывод данных в консоль;" << endl << "5) Вывод отсортированных данных в консоль;" << endl << "6) Выполнить бинарный поиск отсортированных данных;" << endl << "7) Изменить запись по номеру строки;" << endl << "8) Удалить запись по номеру строки;" << endl << "0) Завершить выполнение программы." << endl;
		int enterValueChoice = IntInput("Введите номер действия, которое необходимо выполнить.", "Некорректный номер!");
		switch (enterValueChoice)
		{
		case 1:
		{
			// Ввод массива из консоли
			records = IntInput("Введите количество записей.", "Некорректное количество записей!");
			arr = ArrayConsoleInput(records);
			break;
		}
		case 2:
		{
			// Ввод данных из файла
			ReadFile(arr, records);
			break;
		}
		case 3:
		{
			// Интерфейс выбора: 1) создание нового файла; 2) дополнение новыми записями существующего файла – записи добавляются в конец файла.
			cout << "Выберите способ записи в файл:" << endl << "1) Создание нового файла;" << endl << "2) Дополнение новыми записями существующего файла – записи добавляются в конец файла." << endl;
			int updateFileChoice = IntInput("Введите номер действия, которое необходимо выполнить.", "Некорректный номер!");
			switch (updateFileChoice)
			{
			case 1:
				CreateNewFile();
				break;
			case 2:
				AddToFile();
				break;
			default: break;
			}
			break;
		}
		case 4:
		{
			// Вывод массива в консоль
			if (arr == nullptr) {
				cout << "Выберите пункт 1 или 2 и создайте массив!";
				break;
			}
			else {
				Print(arr, records);
				break;
			}
		}
		case 5:
		{
			// Интерфейс выбора: 1) по возрастанию значений ключевых полей; 2) по убыванию значений ключевых полей.
			cout << "Выберите способ сортировки:" << endl << "1) По возрастанию возраста;" << endl << "2) По уменьшению суммы баллов за КП и ПП." << endl;
			int sortChoice = IntInput("Введите номер действия, которое необходимо выполнить.", "Некорректный номер!");
			switch (sortChoice)
			{
			case 1:
				indexArrayOnAge = IndexArrayGivenAge(arr, records);
				indexArrayOnAge = IncreasingValueBubbleSortIndexArrayGivenAge(indexArrayOnAge, records);
				PrintSortedByAge(arr, indexArrayOnAge, records);
				flgSortedAge = true;
				break;
			case 2:
				indexArrayOnCountSummRate = IndexArrayCountSummRate(arr, records);
				indexArrayOnCountSummRate = DecreasingValueImplementationSortIndexArrayCountSummRate(indexArrayOnCountSummRate, records);
				PrintSortedBySummRate(arr, indexArrayOnCountSummRate, records);
				flgSortedSummRate = true;
				break;
			default: break;
			}
			break;
		}
		case 6:
		{
			// Интерфейс выбора: 1) по возрастанию значений ключевых полей; 2) по убыванию значений ключевых полей.
			cout << "Выберите поле для бинарного поиска:" << endl << "1) Возраст;" << endl << "2) Сумма баллов за КП и ПП." << endl;
			int binarySearchChoice = IntInput("Введите номер действия, которое необходимо выполнить.", "Некорректный номер!");
			switch (binarySearchChoice)
			{
			case 1:
				if (flgSortedAge) {
					int searchAge = IntInput("Введите искомый возраст.", "Ошибка! Повторите ввод!");
					findIndexBinarySearchAge = BinarySearchAgeIterative(indexArrayOnAge, records, searchAge);
					if (findIndexBinarySearchAge == -1) {
						cout << "Элемент не найден!" << endl;
					}
					else {
						Print(arr[findIndexBinarySearchAge]);
					}
				}
				else {
					cout << "Для начала выберите пункт 5 и создайте индекс массивы!";
				}
				break;
			case 2:
				if (flgSortedSummRate) {
					double searchSummRate = DoubleInput("Введите искомую сумму баллов за КП и ПП.", "Ошибка! Повторите ввод!");
					findIndexBinarySearchSummRate = BinarySearchSummRateRecursive(indexArrayOnCountSummRate, 0, records, searchSummRate);
					if (findIndexBinarySearchSummRate == -1) {
						cout << "Элемент не найден!" << endl;
					}
					else {
						Print(arr[findIndexBinarySearchSummRate]);
					}
				}
				else {
					cout << "Для начала выберите пункт 5 и создайте индекс массивы!";
				}
				break;
			default: break;
			}
			break;
		}
		case 7:
		{
			int enterIndexToRewrite = IntInput("Введите номер удаляемой строки.", "Ошибка! Повторите ввод!") - 1;
			if (flgSortedAge && flgSortedSummRate) {
				EditRecord(arr, indexArrayOnAge, indexArrayOnCountSummRate, records, enterIndexToRewrite);
			}
			else {
				cout << "Для начала выберите пункт 5 и создайте индекс массивы!";
			}
			break;
		}
		case 8:
		{
			int enterIndexToDelete = IntInput("Введите номер удаляемой строки.", "Ошибка! Повторите ввод!") - 1;
			if (flgSortedAge && flgSortedSummRate) {
				DeleteRecord(arr, indexArrayOnAge, indexArrayOnCountSummRate, records, enterIndexToDelete);
			}
			else {
				cout << "Для начала выберите пункт 5 и создайте индекс массивы!";
			}
			break;
		}
		case 0:
		{
			cout << "Завершение работы...";
			checkEnd = true;
			break;
		}
		default: { break; }
		}
	}
