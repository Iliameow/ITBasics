// Итерационная реализация бинарного поиска по возрасту фигуриста
int BinarySearchAgeIterative(SkaterOnAge* indexArray, int records, unsigned int findAge)
{
	int mid;
	int left = 0;
	int right = records;
	int result = -1;
	while (left <= right) {
		mid = left + (right - left) / 2;
		if (indexArray[mid].SkaterAge == findAge) {
			result = mid;
			left = mid + 1;
		}
		else if (indexArray[mid].SkaterAge < findAge) {
			left = mid + 1;
		}
		else {
			right = mid - 1;
		}
	}
	return result;
}

// Рекурсивная реализация бинарного поиска по сумме баллов за КП и ПП
int BinarySearchSummRateRecursive(SkaterOnSummRate* indexArray, int left, int right, double findSummRate)
{
	int mid;
	// Элемент не найден (базовый случай)
	if (left > right) {
		return -1;
	}
	mid = left + (right - left) / 2;
	if (indexArray[mid].SkaterSummRate == findSummRate) {
		return mid;
	}
	else if (indexArray[mid].SkaterSummRate > findSummRate) {
		return BinarySearchSummRateRecursive(indexArray, mid + 1, right, findSummRate);
	}
	else {
		return BinarySearchSummRateRecursive(indexArray, left, mid - 1, findSummRate);
	}
}

// Удаление элемента из индекса массива
void DeleteRecordIndexArray(SkaterOnAge* &indexArrayAge, SkaterOnSummRate* &indexArraySummRate, int records, int indexDelete)
{
	// Создаём массив меньшей длины
	SkaterOnAge* newIndexArrayAge = new SkaterOnAge[records];
	// Копируем элементы до удаляемого
	for (int i = 0; i < indexDelete; i++) {
		newIndexArrayAge[i] = indexArrayAge[i];
	}
	// Копируем элементы после удаляемого
	for (int i = indexDelete + 1; i < records; i++) {
		newIndexArrayAge[i - 1] = indexArrayAge[i];
	}
	indexArrayAge = newIndexArrayAge;

	// Сделаем всё то же самое для индекса массива суммы баллов за КП и ПП
	SkaterOnSummRate* newIndexArraySummRate = new SkaterOnSummRate[records];
	for (int i = 0; i < indexDelete; i++) {
		newIndexArraySummRate[i] = indexArraySummRate[i];
	}
	for (int i = indexDelete + 1; i < records; i++) {
		newIndexArraySummRate[i - 1] = indexArraySummRate[i];
	}
	indexArraySummRate = newIndexArraySummRate;
}

// Удаление данных из массива с информацией о фигуристах
void DeleteRecord(FigureSkating* &arr, SkaterOnAge* &indexArrayAge, SkaterOnSummRate* &indexArraySummRate, int &records, int indexDelete)
{
	if (indexDelete < 0 || indexDelete >= records) {
		cout << "Номер элемента вышел за пределы массива! Удаление элемента не выполнено!" << endl;
	}
	else {
		// Создаём массив меньшей длины
		FigureSkating* newArray = new FigureSkating[records - 1];
		// Копируем элементы до удаляемого
		for (int i = 0; i < indexDelete; i++) {
			newArray[i] = arr[i];
		}
		// Копируем элементы после удаляемого
		for (int i = indexDelete + 1; i < records; i++) {
			newArray[i - 1] = arr[i];
		}
		records--;
		DeleteRecordIndexArray(indexArrayAge, indexArraySummRate, records, indexDelete);
		arr = newArray;
		cout << "Запись была успешно удалена." << endl;
	}
}

// Редактирование записи в массиве данных
void EditRecord(FigureSkating* &arr, SkaterOnAge* indexArrayAge, SkaterOnSummRate* indexArraySummRate, int records, int indexEdit)
{
	FigureSkating newStructure = StructureInput();
	arr[indexEdit] = newStructure;
	for (int i = 0; i < records; i++) {
		if (indexArrayAge[i].FullNum == indexEdit) {
			indexArrayAge[i].SkaterAge = newStructure.age;
			indexArrayAge = IncreasingValueBubbleSortIndexArrayGivenAge(indexArrayAge, records);
		}
	}
	for (int i = 0; i < records; i++) {
		if (indexArraySummRate[i].FullNum == indexEdit) {
			indexArraySummRate[i].SkaterSummRate = newStructure.shortProgramRate + newStructure.freeScatingRate;
			indexArraySummRate = DecreasingValueImplementationSortIndexArrayCountSummRate(indexArraySummRate, records);
		}
	}
	cout << "Данные были обновлены." << endl;
}

